else
  export NODE_PATH="/home/prdgmlt010/Desktop/ck/backend-dev2-ck/node_modules/.pnpm/prisma@6.19.3_typescript@5.9.3/node_modules/prisma/node_modules:/home/prdgmlt010/Desktop/ck/backend-dev2-ck/node_modules/.pnpm/prisma@6.19.3_typescript@5.9.3/node_modules:/home/prdgmlt010/Desktop/ck/backend-dev2-ck/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../prisma/build/index.js" "$@"
else
  exec node  "$basedir/../prisma/build/index.js" "$@"
fi
