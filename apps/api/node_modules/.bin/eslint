#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/prdgmlt010/Desktop/ck/backend-dev2-ck/node_modules/.pnpm/eslint@9.39.4_jiti@2.7.0/node_modules/eslint/node_modules:/home/prdgmlt010/Desktop/ck/backend-dev2-ck/node_modules/.pnpm/eslint@9.39.4_jiti@2.7.0/node_modules:/home/prdgmlt010/Desktop/ck/backend-dev2-ck/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/prdgmlt010/Desktop/ck/backend-dev2-ck/node_modules/.pnpm/eslint@9.39.4_jiti@2.7.0/node_modules/eslint/node_modules:/home/prdgmlt010/Desktop/ck/backend-dev2-ck/node_modules/.pnpm/eslint@9.39.4_jiti@2.7.0/node_modules:/home/prdgmlt010/Desktop/ck/backend-dev2-ck/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../eslint/bin/eslint.js" "$@"
else
  exec node  "$basedir/../eslint/bin/eslint.js" "$@"
fi
