{
  "name": "stackforge-parapair",
  "version": "1.0.0",
  "description": "Swipe-based job matching platform",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "start:dev": "turbo run start:dev",
    "start:prod": "turbo run start:prod",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.ts\"",
    "prisma:generate": "cd database && npx prisma generate",
    "prisma:push": "cd database && npx prisma db push",
    "prisma:migrate": "cd database && npx prisma migrate dev",
    "prisma:studio": "cd database && npx prisma studio"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "database"
  ]
}
